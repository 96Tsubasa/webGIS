const axios = require("axios");
const fs = require("fs");
const path = require("path");
const { exec } = require("child_process");

const BASE_URL = "https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25.pl";

// config
const date = "20260506";
const cycle = "18";
const forecastHours = Array.from({ length: 9 }, (_, i) => i * 3);

// dùng env cho Docker
const DATA_DIR = process.env.DATA_DIR || path.join(__dirname, "../data");

const GRIB_DIR = path.join(DATA_DIR, "grib");
const TIF_DIR = path.join(DATA_DIR, "geotiff");

// tạo folder
[GRIB_DIR, TIF_DIR].forEach(dir => {
  if (!fs.existsSync(dir)) {
    fs.mkdirSync(dir, { recursive: true });
  }
});

// bounding box
const bbox = {
  leftlon: 100.1,
  rightlon: 111.8,
  toplat: 25.6,
  bottomlat: 6.4
};

async function downloadFile(fHour) {
  const fStr = String(fHour).padStart(3, "0");

  const url = `${BASE_URL}?file=gfs.t${cycle}z.pgrb2.0p25.f${fStr}` +
    `&lev_2_m_above_ground=on` +
    `&var_TMP=on` +
    `&subregion=` +
    `&leftlon=${bbox.leftlon}` +
    `&rightlon=${bbox.rightlon}` +
    `&toplat=${bbox.toplat}` +
    `&bottomlat=${bbox.bottomlat}` +
    `&dir=%2Fgfs.${date}%2F${cycle}%2Fatmos`;

  const filePath = path.join(GRIB_DIR, `temp_f${fStr}.grib2`);

  console.log("Downloading:", filePath);

  const response = await axios({
    method: "GET",
    url,
    responseType: "stream"
  });

  const writer = fs.createWriteStream(filePath);
  response.data.pipe(writer);

  return new Promise((resolve, reject) => {
    writer.on("finish", () => resolve(filePath));
    writer.on("error", reject);
  });
}

// convert GRIB → GeoTIFF
function convertToTif(gribPath) {
  return new Promise((resolve, reject) => {
    const fileName = path.basename(gribPath, ".grib2");
    const tifPath = path.join(TIF_DIR, `${fileName}.tif`);

    const cmd = `gdal_translate -of GTiff -b 1 "${gribPath}" "${tifPath}"`;

    console.log("Converting:", cmd);

    exec(cmd, (err, stdout, stderr) => {
      if (err) {
        console.error("GDAL error:", stderr);
        return reject(err);
      }
      resolve(tifPath);
    });
  });
}

async function run() {
  for (const h of forecastHours) {
    try {
      // 1. download
      const gribPath = await downloadFile(h);

      // 2. convert
      const tifPath = await convertToTif(gribPath);

      console.log(`Done f${h} → ${tifPath}`);
    } catch (err) {
      console.error(`Error f${h}:`, err.message);
    }
  }
}

run();